# Скопируйте в .env при необходимости переопределить настройки.
# В проде (Render/Railway) можно подать DATABASE_URL как есть (postgres://… или
# postgresql://…) — он автоматически приводится к async-драйверу asyncpg.
MEDARCHIVE_DATABASE_URL=postgresql+asyncpg://medarchive:medarchive@db:5432/medarchive
MEDARCHIVE_MATCH_THRESHOLD=0.85

# Эмбеддинги (sentence-transformers + torch ~ГБ). В проде на маленьком инстансе
# рекомендуется false (остаётся fuzzy-матч), иначе возможен OOM/долгая сборка.
MEDARCHIVE_USE_EMBEDDINGS=true
MEDARCHIVE_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MEDARCHIVE_TESSERACT_LANG=rus+kaz+eng

# Конкурентная обработка документов в фоне (своя сессия БД на задачу).
MEDARCHIVE_PROCESS_CONCURRENCY=4

# Авто-сид справочника при пустой БД (для свежего деплоя). Пусто → не сидить.
MEDARCHIVE_SEED_CATALOG_PATH=data/samples/catalog.json

# LLM-извлечение (OpenAI): fallback для кривых файлов + vision-OCR сканов.
# Без ключа пайплайн работает на Tesseract/regex (LLM просто отключён).
MEDARCHIVE_OPENAI_API_KEY=
MEDARCHIVE_OPENAI_MODEL=gpt-4o-mini
MEDARCHIVE_USE_LLM_EXTRACTION=true

# Docling-фоллбэк для PDF (ML-структура таблиц), пробуется ПЕРЕД LLM.
# DOCLING_SERVE_URL задан → удалённый GPU-путь (docling-serve/RunPod);
# пусто → локальный пакет (нужен `pip install -e ".[docling]"`, ~1ГБ моделей).
MEDARCHIVE_USE_DOCLING=true
MEDARCHIVE_DOCLING_SERVE_URL=
MEDARCHIVE_DOCLING_MAX_PAGES=12
MEDARCHIVE_DOCLING_TIMEOUT_SECONDS=120
